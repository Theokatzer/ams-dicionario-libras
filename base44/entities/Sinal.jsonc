    },
    "sinalizante_menor": {
      "type": "boolean",
      "default": false,
      "title": "Sinalizante Menor de Idade"
    },
    "nome_responsavel_legal": {
      "type": "string",
      "title": "Nome do Respons\u00e1vel Legal"
    },
    "cpf_responsavel": {
      "type": "string",
      "title": "CPF do Respons\u00e1vel"
