      "type": "string",
      "title": "URL do V\u00eddeo"
    },
    "foto_mao_url": {
      "type": "string",
      "title": "URL da Foto da M\u00e3o"
    },
    "ponto_articulacao": {
      "type": "string",
      "title": "Ponto de Articula\u00e7\u00e3o"
    },
    "configuracao_mao": {
      "type": "string",
      "title": "Configura\u00e7\u00e3o de M\u00e3o"
    },
    "disposicao_maos": {
      "type": "string",
      "enum": [
