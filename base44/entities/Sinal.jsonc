        "Cruzada",
        "Entrela\u00e7ada",
        "Uma sobre a outra",
        "Uma ao lado da outra",
        "N/A"
      ],
      "title": "Disposi\u00e7\u00e3o das M\u00e3os"
    },
    "orientacao_mao": {
      "type": "string",
      "title": "Orienta\u00e7\u00e3o da M\u00e3o"
    },
    "regiao_contato": {
      "type": "string",
      "title": "Regi\u00e3o de Contato"
    },
    "componente_nao_manual": {
      "type": "string",
      "enum": [
